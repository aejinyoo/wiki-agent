# ════════════════════════════════════════════════════════════
# 필수
# ════════════════════════════════════════════════════════════

# Google Gemini API 키
#   1. https://aistudio.google.com/apikey 접속 (구글 계정 로그인)
#   2. "Create API key" 클릭
#   3. 발급된 키 (AIza… 로 시작) 복사해서 아래에 붙여넣기
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 위키 데이터 repo 로컬 경로 (GitHub Actions에선 checkout 경로로 자동 override)
WIKI_REPO_PATH=/Users/aejin/dev/wiki


# ════════════════════════════════════════════════════════════
# 선택: GitHub Issues inbox (Actions/서버 실행 시)
# ════════════════════════════════════════════════════════════
# 둘 다 채워지면 "issues 모드" 자동 활성화. 비우면 inbox.md 파일 모드.

# "owner/repo" 형식. iOS Shortcut이 이슈를 생성할 대상.
GITHUB_WIKI_REPO=aejinyoo/wiki

# PAT (로컬 테스트용). GitHub Actions에선 자동 GITHUB_TOKEN 사용.
# Fine-grained PAT — aejinyoo/wiki repo의 Issues(RW), Contents(RW) 권한
WIKI_REPO_TOKEN=

# 이슈 라벨 이름 (기본값 'inbox')
INBOX_LABEL=inbox


# ════════════════════════════════════════════════════════════
# 모델 (Gemini)
#   MODEL_HAIKU  = 분류용 (빠르고 저렴)        → 기본값 gemini-2.5-flash-lite
#   MODEL_SONNET = 브리프·큐레이션용 (고품질) → 기본값 gemini-2.5-pro
# ════════════════════════════════════════════════════════════
MODEL_HAIKU=gemini-2.5-flash-lite
MODEL_SONNET=gemini-2.5-pro


# ════════════════════════════════════════════════════════════
# 가드레일
# ════════════════════════════════════════════════════════════
DAILY_TOKEN_CAP_SONNET=15000
DAILY_TOKEN_CAP_HAIKU=10000
CLASSIFIER_DAILY_ITEM_CAP=30
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════════
# (구버전/레거시) — 더 이상 사용 안 함. 비워두면 자동으로 비활성화.
# ════════════════════════════════════════════════════════════
# ICLOUD_MIRROR_PATH=
# AGENT_HOME=
